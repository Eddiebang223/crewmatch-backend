generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String
  companyName String?
  createdAt DateTime @default(now())
  
  jobs      Job[]    @relation("GCJobs")
  bids      Bid[]
}

model Job {
  id          String   @id @default(cuid())
  title       String
  trade       String
  description String
  location    String
  startDate   DateTime
  endDate     DateTime
  hours       Int
  rateMin     Float
  rateMax     Float
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  
  gcId        String
  gc          User     @relation("GCJobs", fields: [gcId], references: [id])
  bids        Bid[]
}

model Bid {
  id          String   @id @default(cuid())
  proposedRate Float
  message     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  contractorId String
  contractor   User    @relation(fields: [contractorId], references: [id])
}
